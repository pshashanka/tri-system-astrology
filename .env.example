# Tri-System Astrology — Environment Variables

# --- Required for v1 API Authentication ---
# Generate with: openssl rand -hex 32
ASTRO_API_KEY=

# --- Required for Rate Limiting (production) ---
# Get from https://console.upstash.com (free tier available)
# Without these, rate limiting falls back to allow-all mode (fine for development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: Legacy /api/reading endpoint (AI synthesis) ---
# Only needed if using the original Next.js frontend with AI-generated readings
# Not needed for Custom GPT or MCP usage (the AI client does its own synthesis)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
