# Tri-System Astrology API — Environment Variables

# --- Required for v1 API Authentication ---
# Generate with: openssl rand -hex 32
ASTRO_API_KEY=

# --- Required for Rate Limiting (production) ---
# Get from https://console.upstash.com (free tier available)
# Without these, rate limiting falls back to allow-all mode (fine for development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: Server-side AI synthesis ---
# Only needed if you later add a dedicated reading endpoint.
# Not required for the current GPT + MCP API-only deployment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Optional: Extra browser origins for v1 API CORS ---
# Comma-separated list, for example: https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# --- Optional: Public HTTPS origin for GPT/OpenAPI publishing ---
# Set this when using a custom domain so consent screens and imported specs use your branded URL.
PUBLIC_BASE_URL=
