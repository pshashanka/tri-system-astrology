{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
  },
  "include": [
    "types.d.ts",
    "server.ts",
    "lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "mcp",
    "__tests__"
  ]
}